# ─── Ansible Inventory ───────────────────────────────────────────────
# When Ansible runs inside Docker, it connects back to the Docker host
# via the special hostname: host.docker.internal
# This lets the Ansible container control the host's Docker daemon.

[local]
host.docker.internal ansible_connection=local

[all:vars]
ansible_python_interpreter=/usr/bin/python3
